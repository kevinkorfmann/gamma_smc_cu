\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Benchmark against existing methods.} (\textit  {Left})\nobreakspace  {}Single-pair inference time for sequences of 1--50\nobreakspace  {}Mb: PSMC (25\nobreakspace  {}EM iterations), \texttt  {gamma\_smc}, and \texttt  {tmrca.cu} on GPU\spacefactor \@m {}. \texttt  {tmrca.cu} achieves 15--143$\times $ speedup over \texttt  {gamma\_smc} and orders of magnitude over PSMC\spacefactor \@m {}. (\textit  {Right})\nobreakspace  {}Multi-pair throughput at 1\nobreakspace  {}Mb for 10, 50, and 100 haplotypes. \texttt  {tmrca.cu}'s batch parallelism yields 48--182$\times $ speedup, with the advantage growing as the number of pairs increases.\relax }}{18}{figure.caption.20}\protected@file@percent }
\newlabel{fig:competitors}{{5}{18}{\textbf {Benchmark against existing methods.} (\textit {Left})~Single-pair inference time for sequences of 1--50~Mb: PSMC (25~EM iterations), \texttt {gamma\_smc}, and \texttt {tmrca.cu} on GPU\@. \texttt {tmrca.cu} achieves 15--143$\times $ speedup over \texttt {gamma\_smc} and orders of magnitude over PSMC\@. (\textit {Right})~Multi-pair throughput at 1~Mb for 10, 50, and 100 haplotypes. \texttt {tmrca.cu}'s batch parallelism yields 48--182$\times $ speedup, with the advantage growing as the number of pairs increases.\relax }{figure.caption.20}{}}
