\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Kernel optimization trajectory and throughput scaling.} (\textit  {Left})\nobreakspace  {}Cumulative throughput (millions of site$\cdot $pairs/s) after each of the five optimization phases, measured on an A100 with $K = 32$, $S = 50{,}000$\nobreakspace  {}sites. The dominant contribution comes from emission precomputation and fast-math intrinsics (Phase\nobreakspace  {}1, $3.5\times $). (\textit  {Right})\nobreakspace  {}Throughput as a function of the number of pairs, demonstrating near-constant performance from 500 to 5{,}000\nobreakspace  {}pairs.\relax }}{13}{figure.caption.14}\protected@file@percent }
