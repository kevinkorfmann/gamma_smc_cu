\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {EM recovery of the coalescent prior under a bottleneck.} Step plot comparing the true coalescent time distribution (black) under a bottleneck scenario ($N_\mathrm  {e}: 10{,}000 \to 500 \to 20{,}000$) with the initial constant-$N_\mathrm  {e}$ prior (dashed grey) and the EM-estimated prior after 10\nobreakspace  {}iterations (blue, $K = 64$). The EM successfully recovers the bimodal structure characteristic of a population bottleneck.\relax }}{17}{figure.caption.19}\protected@file@percent }
\newlabel{fig:prior_recovery}{{4}{17}{\textbf {EM recovery of the coalescent prior under a bottleneck.} Step plot comparing the true coalescent time distribution (black) under a bottleneck scenario ($\Ne : 10{,}000 \to 500 \to 20{,}000$) with the initial constant-$\Ne $ prior (dashed grey) and the EM-estimated prior after 10~iterations (blue, $K = 64$). The EM successfully recovers the bimodal structure characteristic of a population bottleneck.\relax }{figure.caption.19}{}}
