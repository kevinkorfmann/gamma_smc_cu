\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Projected wall-clock time for chromosome\nobreakspace  {}1 all-pairs inference.} Log-log plot of total compute time versus sample size ($2N$) for human chr1 ($S = 4.5$M SNPs) on a single A100. The baseline kernel (9.1M site$\cdot $pairs/s, dashed) is compared with the optimized kernel (93M site$\cdot $pairs/s, solid). Horizontal reference lines indicate 1\nobreakspace  {}hour, 1\nobreakspace  {}day, and 1\nobreakspace  {}week. At $2N = 1{,}000$, the optimized kernel completes in ${\sim }\,7$\nobreakspace  {}hours versus 69\nobreakspace  {}hours at baseline.\relax }}{14}{figure.caption.16}\protected@file@percent }
\newlabel{fig:wallclock}{{2}{14}{\textbf {Projected wall-clock time for chromosome~1 all-pairs inference.} Log-log plot of total compute time versus sample size ($2N$) for human chr1 ($S = 4.5$M SNPs) on a single A100. The baseline kernel (9.1M site$\cdot $pairs/s, dashed) is compared with the optimized kernel (93M site$\cdot $pairs/s, solid). Horizontal reference lines indicate 1~hour, 1~day, and 1~week. At $2N = 1{,}000$, the optimized kernel completes in ${\sim }\,7$~hours versus 69~hours at baseline.\relax }{figure.caption.16}{}}
