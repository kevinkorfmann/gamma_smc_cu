\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Scaling comparison with \texttt  {gamma\_smc}.} (\textit  {a})\nobreakspace  {}Wall-clock time versus number of haplotypes at 1\nobreakspace  {}Mb; annotations show the speedup factor at each point. (\textit  {b})\nobreakspace  {}Wall-clock time versus sequence length at $n = 50$ haplotypes. (\textit  {c})\nobreakspace  {}Speedup heatmap across the full grid of sample sizes and sequence lengths. Speedup ranges from $13\times $ ($n = 200$, $5$\nobreakspace  {}Mb) to $453\times $ ($n = 10$, $1$\nobreakspace  {}Mb).\relax }}{19}{figure.caption.21}\protected@file@percent }
\newlabel{fig:gamma_deep}{{6}{19}{\textbf {Scaling comparison with \texttt {gamma\_smc}.} (\textit {a})~Wall-clock time versus number of haplotypes at 1~Mb; annotations show the speedup factor at each point. (\textit {b})~Wall-clock time versus sequence length at $n = 50$ haplotypes. (\textit {c})~Speedup heatmap across the full grid of sample sizes and sequence lengths. Speedup ranges from $13\times $ ($n = 200$, $5$~Mb) to $453\times $ ($n = 10$, $1$~Mb).\relax }{figure.caption.21}{}}
